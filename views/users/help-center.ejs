<% layout("/layouts/boilerplate") %>

<div class="row mt-4 mb-4">
  <div class="col-8 offset-2">
    <h2 class="mb-3">Help Center</h2>
    <p class="text-muted">Need help with your account, profile, or wishlist? Start here.</p>

    <div class="card mb-3">
      <div class="card-body">
        <h5 class="card-title">Profile Updates</h5>
        <p class="card-text mb-0">Open your profile to edit full name, date of birth, and email from the edit forms.</p>
      </div>
    </div>

    <div class="card mb-3">
      <div class="card-body">
        <h5 class="card-title">Wishlist Help</h5>
        <p class="card-text mb-0">Use Add and Remove buttons on your profile page to manage your wishlist quickly.</p>
      </div>
    </div>

    <div class="card mb-3">
      <div class="card-body">
        <h5 class="card-title">Forgot Password?</h5>
        <p class="card-text mb-0">
          Reset your password from
          <a href="/forgot-password">Forgot Password</a>.
        </p>
      </div>
    </div>

    <a href="/profile" class="btn btn-dark">Back To Profile</a>
  </div>
</div>
