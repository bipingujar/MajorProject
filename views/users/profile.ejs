<% layout("/layouts/boilerplate") %>
<style>
  .profile-page-wrap {
    min-height: calc(100vh - 10rem);
    padding: 2rem 0 3rem;
    background: linear-gradient(160deg, #e7edf3 0%, #f3f6fa 50%, #eaf0f5 100%);
  }

  .profile-panel {
    max-width: 900px;
    margin: 0 auto;
    background: #f4f7fb;
    border-radius: 14px;
    box-shadow: 0 10px 50px rgba(28, 42, 62, 0.18);
    padding: 2.25rem 2.25rem 2.5rem;
    border: 1px solid #d9e1ea;
  }

  .profile-title {
    font-size: 2rem;
    line-height: 0.5;
    margin-bottom: 1.75rem;
    font-family: Georgia, "Times New Roman", serif;
    color: #17396a;
    font-weight: 500;
  }

  .profile-field {
    margin-bottom: 0.5rem;
  }

  .profile-summary {
    border: 1px solid #d3dce6;
    background: #eef3f8;
    border-radius: 12px;
    padding: 0.9rem 1rem;
    margin-bottom: 1rem;
  }

  .profile-summary-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.45rem 1rem;
  }

  .profile-summary-item {
    font-size: 0.95rem;
    color: #1d2c3d;
  }

  .profile-summary-item b {
    color: #0f2238;
  }

  .profile-field label {
    display: block;
    font-size: 1rem;
    margin-bottom: 0.4rem;
    color: #111;
  }

  .profile-input-row {
    display: flex;
    gap: 0.6rem;
    align-items: center;
  }

  .profile-input {
    height: 2rem;
    border-radius: 0.7rem;
    border: 2px solid #9da9b7;
    padding: 0.65rem 1rem;
    font-size: 1rem;
    color: #222;
    background-color: #f7fafd;
    flex: 1;
  }

  .profile-input:focus {
    outline: none;
    border-color: #17396a;
    box-shadow: 0 0 0 0.15rem rgba(23, 57, 106, 0.15);
  }

  .profile-action-btn {
    height: 2rem;
    border: 1px solid #fe424d;
    border-radius: 0.7rem;
    background: #fe424d;
    color: #fff;
    font-size: 0.95rem;
    min-width: 96px;
    padding: 0 0.9rem;
  }

  .profile-action-btn:hover {
    background: #fe424d;
  }

  .profile-password-row {
    flex-wrap: wrap;
    align-items: stretch;
  }

  .profile-password-row .profile-input {
    min-width: 180px;
  }

  .profile-section-title {
    font-size: 2rem;
    line-height: 1.05;
    margin: 1.6rem 0 1rem;
    font-family: Georgia, "Times New Roman", serif;
    color: #101827;
    font-weight: 700;
  }

  .wishlist-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .wishlist-item {
    border: 2px  #9aa4b1;
    border-radius: 14px;
    padding: 0.8rem;
    background: #f7fafd;
    display: flex;
    flex-direction: column;
    min-height: 220px;
  }

  .wishlist-thumb-link {
    text-decoration: none;
    color: inherit;
  }

  .wishlist-thumb {
    width: 100%;
    height: 118px;
    object-fit: cover;  
    border-radius: 10px;
    margin-bottom: 0.55rem;
  }

  .wishlist-name {
    font-size: 1rem;
    font-weight: 500;
    margin-bottom: 0.2rem;
    line-height: 1.3;
  }

  .wishlist-meta {
    font-size: 0.85rem;
    color: #3a4654;
    margin-bottom: 0.65rem;
  }

  .wishlist-price {
    margin-top: auto;
    font-size: 1rem;
    font-weight: 700;
    color: #111;
    background: #e6ebf1;
    display: inline-block;
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
    margin-bottom: 0.5rem;
  }

  .wishlist-btn {
    width: 100%;
    border-radius: 0.6rem;
    padding: 0.38rem 0.7rem;
    font-size: 0.92rem;
    border: 1px solid #25364b;
    background: #fff;
    color: #25364b;
  }

  .wishlist-btn.wishlist-add-btn {
    background: #17396a;
    color: #fff;
    border-color: #17396a;
  }

  .owner-listing-actions {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;
    margin-top: 0.15rem;
  }

  .admin-payment-settings-panel {
    border: 1px solid #d3dce6;
    background: #eef3f8;
    border-radius: 12px;
    padding: 1rem;
    margin-bottom: 1rem;
  }

  .admin-upi-qr-preview {
    width: 150px;
    max-width: 100%;
    border-radius: 12px;
    border: 1px solid #d5dce4;
    background: #fff;
    padding: 0.2rem;
  }

  .profile-top-actions {
    display: flex;
    justify-content: flex-end;
    margin-bottom: 0.4rem;
  }

  html[data-theme="dark"] .profile-page-wrap {
    background: linear-gradient(160deg, #0f141b 0%, #151c25 50%, #0f141b 100%);
  }

  html[data-theme="dark"] .profile-panel {
    background: #1b2027;
    border-color: #334155;
  }

  html[data-theme="dark"] .profile-title,
  html[data-theme="dark"] .profile-section-title,
  html[data-theme="dark"] .profile-field label,
  html[data-theme="dark"] .wishlist-name,
  html[data-theme="dark"] .wishlist-price {
    color: #f3f4f6 !important;
  }

  html[data-theme="dark"] .profile-summary {
    background: #111827;
    border-color: #334155;
  }

  html[data-theme="dark"] .profile-summary-item,
  html[data-theme="dark"] .profile-summary-item b,
  html[data-theme="dark"] .wishlist-meta {
    color: #d1d5db !important;
  }

  html[data-theme="dark"] .profile-input {
    background-color: #0f172a;
    border-color: #475569;
    color: #f9fafb;
  }

  html[data-theme="dark"] .profile-input::placeholder {
    color: #9ca3af;
  }

  html[data-theme="dark"] .wishlist-item {
    background: #0f172a;
    border-color: #334155;
  }

  html[data-theme="dark"] .admin-payment-settings-panel {
    background: #111827;
    border-color: #334155;
  }

  html[data-theme="dark"] .admin-upi-qr-preview {
    border-color: #334155;
    background: #0f172a;
  }

  @media (max-width: 991px) {
    .profile-panel {
      padding: 1.5rem 1rem 1.75rem;
    }

    .profile-title,
    .profile-section-title {
      font-size: 2.2rem;
    }

    .profile-field label {
      font-size: 1.55rem;
    }

    .profile-input {
      font-size: 1.35rem;
      height: 2.8rem;
    }

    .profile-action-btn {
      height: 2.8rem;
      min-width: 82px;
      font-size: 0.85rem;
    }

    .wishlist-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 575px) {
    .profile-summary-grid {
      grid-template-columns: 1fr;
    }

    .wishlist-grid {
      grid-template-columns: 1fr;
    }

    .profile-input-row {
      flex-direction: column;
      align-items: stretch;
    }

    .profile-action-btn {
      width: 100%;
    }
  }
</style>

<div class="profile-page-wrap">
  <div class="profile-panel">
    <div class="profile-top-actions">
      <a href="/help-center" class="btn btn-outline-dark btn-sm">Help Center</a>
    </div>

    <h3 class="profile-title">My Profile</h3>
    <% const dobValue = user.dateOfBirth ? new Date(user.dateOfBirth).toISOString().split("T")[0] : ""; %>

    <div class="profile-summary">
      <div class="profile-summary-grid">
        <div class="profile-summary-item"><b>Username:</b> <%= user.username || "Not set" %></div>
        <div class="profile-summary-item"><b>Email:</b> <%= user.email || "Not set" %></div>
        <div class="profile-summary-item"><b>Full Name:</b> <%= user.fullName || "Not set" %></div>
        <div class="profile-summary-item"><b>Date of Birth:</b> <%= dobValue || "Not set" %></div>
        <div class="profile-summary-item"><b>Password:</b> ******** (hidden)</div>
      </div>
    </div>

    <div class="profile-field">
      <label for="fullNameInput"><b>Full Name</b></label>
      <form action="/profile/full-name" method="POST" class="profile-input-row">
        <input
          id="fullNameInput"
          class="profile-input"
          type="text"
          name="fullName"
          value="<%= user.fullName || '' %>"
          placeholder="Change full name"
        />
        <button class="profile-action-btn" type="submit">Edit</button>
      </form>
    </div>

    <div class="profile-field">
      <label for="dobInput"><b>Date of Birth</b></label>
      <form action="/profile/date-of-birth" method="POST" class="profile-input-row">
        <input id="dobInput" class="profile-input" type="date" name="dateOfBirth" value="<%= dobValue %>" placeholder="Change date of birth (YYYY-MM-DD)" />
        <button class="profile-action-btn" type="submit">Edit</button>
      </form>
    </div>

    <div class="profile-field">
      <label for="emailInput"><b>Email</b></label>
      <form action="/profile/email" method="POST" class="profile-input-row">
        <input id="emailInput" class="profile-input" type="email" name="email" value="<%= user.email || '' %>" placeholder="Change email" required />
        <button class="profile-action-btn" type="submit">Edit</button>
      </form>
    </div>

    <div class="profile-field">
      <label for="currentPasswordInput"><b>Change Password</b></label>
      <form action="/profile/password" method="POST" class="profile-input-row profile-password-row">
        <input
          id="currentPasswordInput"
          class="profile-input"
          type="password"
          name="currentPassword"
          placeholder="Current password"
          autocomplete="current-password"
          required
        />
        <input
          id="newPasswordInput"
          class="profile-input"
          type="password"
          name="newPassword"
          placeholder="New password"
          minlength="6"
          autocomplete="new-password"
          required
        />
        <input
          id="confirmNewPasswordInput"
          class="profile-input"
          type="password"
          name="confirmNewPassword"
          placeholder="Confirm new password"
          minlength="6"
          autocomplete="new-password"
          required
        />
        <button class="profile-action-btn" type="submit">Update</button>
      </form>
    </div>

    <% if (user.isAdmin) { %>
      <h3 class="profile-section-title">Admin Payment Settings</h3>
      <div class="admin-payment-settings-panel">
        <form method="POST" action="/profile/payment-settings" enctype="multipart/form-data">
          <div class="profile-field">
            <label for="adminUpiIdInput"><b>UPI ID</b></label>
            <div class="profile-input-row">
              <input
                id="adminUpiIdInput"
                class="profile-input"
                type="text"
                name="payment[upiId]"
                value="<%= paymentSettings?.upiId || '' %>"
                placeholder="example@upi"
              />
            </div>
          </div>

          <div class="profile-field">
            <label for="adminQrImageInput"><b>QR Image</b></label>
            <div class="profile-input-row">
              <input
                id="adminQrImageInput"
                class="form-control"
                type="file"
                name="payment[qrImage]"
                accept="image/*"
              />
            </div>
            <small class="text-muted">Maximum file size: 2MB</small>
          </div>

          <% if (paymentSettings?.qrImage?.url) { %>
            <div class="profile-field">
              <p class="mb-1"><strong>Current QR:</strong></p>
              <img src="<%= paymentSettings.qrImage.url %>" alt="Admin UPI QR" class="admin-upi-qr-preview" />
            </div>
          <% } %>

          <button class="profile-action-btn" type="submit">Save Payment Settings</button>
        </form>
      </div>
    <% } %>

    <h3 class="profile-section-title">My Uploaded Wanderstay listings</h3>
    <% if (ownerListings && ownerListings.length) { %>
      <div class="wishlist-grid">
        <% for (let listing of ownerListings) { %>
          <% const previewImage = (listing.images && listing.images.length) ? listing.images[0].url : (listing.image ? listing.image.url : ""); %>
          <div class="wishlist-item">
            <a href="/listings/<%= listing._id %>" class="wishlist-thumb-link">
              <img src="<%= previewImage %>" class="wishlist-thumb" alt="owner_listing_image" />
              <div class="wishlist-name"><%= listing.title %></div>
            </a>
            <div class="wishlist-meta"><%= listing.location %>, <%= listing.country %></div>
            <div class="wishlist-price">&#8377;<%= Number(listing.price || 0).toLocaleString("en-IN") %></div>
            <div class="owner-listing-actions">
              <a class="wishlist-btn text-center text-decoration-none" href="/listings/<%= listing._id %>">View</a>
              <a class="wishlist-btn wishlist-add-btn text-center text-decoration-none" href="/listings/<%= listing._id %>/edit">Edit</a>
            </div>
          </div>
        <% } %>
      </div>
    <% } else { %>
      <div class="alert alert-secondary">You have not uploaded any Wanderstay listings yet.</div>
    <% } %>

    <h2 class="profile-section-title">My Wishlist</h2>
    <% if (user.wishlist && user.wishlist.length) { %>
      <div class="wishlist-grid">
        <% for (let listing of user.wishlist) { %>
          <% const previewImage = (listing.images && listing.images.length) ? listing.images[0].url : (listing.image ? listing.image.url : ""); %>
          <div class="wishlist-item">
            <a href="/listings/<%= listing._id %>" class="wishlist-thumb-link">
              <img src="<%= previewImage %>" class="wishlist-thumb" alt="wishlist_listing_image" />
              <div class="wishlist-name"><%= listing.title %></div>
            </a>
            <div class="wishlist-meta"><%= listing.location %>, <%= listing.country %></div>
            <div class="wishlist-price">&#8377;<%= Number(listing.price || 0).toLocaleString("en-IN") %></div>
            <form method="POST" action="/profile/wishlist/<%= listing._id %>/remove">
              <button class="wishlist-btn" type="submit">Remove</button>
            </form>
          </div>
        <% } %>
      </div>
    <% } else { %>
      <div class="alert alert-secondary">Your wishlist is empty.</div>
    <% } %>

    <h2 class="profile-section-title">Add To Wishlist</h2>
    <% if (suggestedListings && suggestedListings.length) { %>
      <div class="wishlist-grid">
        <% for (let listing of suggestedListings) { %>
          <% const previewImage = (listing.images && listing.images.length) ? listing.images[0].url : (listing.image ? listing.image.url : ""); %>
          <div class="wishlist-item">
            <a href="/listings/<%= listing._id %>" class="wishlist-thumb-link">
              <img src="<%= previewImage %>" class="wishlist-thumb" alt="suggested_listing_image" />
              <div class="wishlist-name"><%= listing.title %></div>
            </a>
            <div class="wishlist-meta"><%= listing.location %>, <%= listing.country %></div>
            <div class="wishlist-price">&#8377;<%= Number(listing.price || 0).toLocaleString("en-IN") %></div>
            <form method="POST" action="/profile/wishlist/<%= listing._id %>/add">
              <button class="wishlist-btn wishlist-add-btn" type="submit">Add</button>
            </form>
          </div>
        <% } %>
      </div>
    <% } else { %>
      <div class="alert alert-secondary">No more listings to add right now.</div>
    <% } %>
  </div>
</div>

