<% layout("/layouts/boilerplate") %>

<div class="row mt-5">
    <div class="col-6 offset-3">
        <h2>Verify OTP & Reset Password</h2>
        <p class="text-muted">OTP sent to: <%= email %></p>

        <form action="/reset-password/otp" method="POST" class="needs-validation" novalidate>
            <div class="mb-3">
                <label for="otp" class="form-label">6-digit OTP</label>
                <input
                    id="otp"
                    type="text"
                    name="otp"
                    class="form-control"
                    pattern="[0-9]{6}"
                    maxlength="6"
                    placeholder="Enter OTP"
                    required
                />
                <div class="invalid-feedback">Please enter valid 6-digit OTP.</div>
            </div>

            <div class="mb-3">
                <label for="password" class="form-label">New Password</label>
                <input
                    id="password"
                    type="password"
                    name="password"
                    class="form-control"
                    minlength="6"
                    required
                />
                <div class="invalid-feedback">Password must be at least 6 characters.</div>
            </div>

            <div class="mb-3">
                <label for="confirmPassword" class="form-label">Confirm Password</label>
                <input
                    id="confirmPassword"
                    type="password"
                    name="confirmPassword"
                    class="form-control"
                    minlength="6"
                    required
                />
                <div class="invalid-feedback">Please confirm your password.</div>
            </div>

            <button class="btn btn-success w-100">Reset Password</button>

            <div class="mt-3 text-center">
                <a href="/forgot-password" class="text-decoration-none">Resend OTP</a>
            </div>
        </form>
    </div>
</div>
