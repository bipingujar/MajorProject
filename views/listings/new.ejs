<!DOCTYPE html>
<html lang="en">
    <%layout ("/layouts/boilerplate") %>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Wanderstay</title>

    <!-- ✅ Add Bootstrap CSS -->
    <link 
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" 
        rel="stylesheet"
    >
</head>
<body class="container mt-4">
    <div class="row mt-3">
        <div class="col-8 offset-2">
            <!--<br /><br /> -->
    <h2>Create a New Listing</h2>
    <form 
    method="POST" 
    action="/listings" 
    novalidate class="needs-validation" 
    enctype="multipart/form-data">
        <div class="mb-3">
            <label for="title" class="form-label">Title</label>
            <input 
                name="listing[title]" 
                placeholder="Add a catchy title" 
                type="text" 
                class="form-control"
                required
            />
            <div class="valid-feedback">Title looks good!</div>
        </div>        
        <div class="mb-3">
            <label for="description" class="form-label">Description</label>  
            <textarea 
                name="listing[description]" 
                class="form-control"
                required
            ></textarea>
            <div class="invalid-feedback">Please enter a short description</div>
        </div>
        
        <div class="mb-3">
            <label for="images" class="form-label">Upload Listing Images (max 10)</label>
            <input
                id="images"
                name="listing[images][]"
                type="file"
                class="form-control"
                accept="image/*"
                multiple
                required
            />
            <div class="form-text">You can select up to 10 images.</div>
        </div>

        <div class="row">
            <div class="mb-3 col-md-4">
            <label for="price" class="form-label">Price</label>
            <input 
                name="listing[price]" 
                placeholder="1200"  
                class="form-control"
                required
            />
            <div class="invalid-feedback">Price should be valid</div>
        </div>

        <div class="mb-3 col-md-8">
            <label for="country" class="form-label">Country</label>
            <input 
                name="listing[country]" 
                placeholder="India" 
                type="text" 
                class="form-control"
                required
            />
             <div class="invalid-feedback">Country name should be valid</div>
        </div>

        </div>

        <div class="mb-3">
            <label for="category" class="form-label">Category</label>
            <select id="category" name="listing[category]" class="form-select" required>
                <option value="">Select category</option>
                <option value="rooms">Rooms</option>
                <option value="iconic-cities">Iconic Cities</option>
                <option value="mountains">Mountains</option>
                <option value="castles">Castles</option>
                <option value="arctic">Arctic</option>
                <option value="camping">Camping</option>
                <option value="farms">Farms</option>
                <option value="domes">Domes</option>
                <option value="boats">Boats</option>
            </select>
            <div class="invalid-feedback">Please select a category.</div>
        </div>

        <div class="mb-3">
            <label for="location" class="form-label">Location</label>
            <input 
                name="listing[location]" 
                placeholder="Jaipur, Rajasthan" 
                type="text" 
                class="form-control"
                required
            />
             <div class="invalid-feedback">Location should be valid</div>
        </div>

        <div class="mb-3">
            <h5 class="mb-2">Amenities (Admin/Owner can set Yes/No)</h5>
            <div class="row g-2">
                <div class="col-md-6">
                    <label class="form-label">Kitchen</label>
                    <select class="form-select" name="listing[amenities][kitchen]">
                        <option value="false" selected>No</option>
                        <option value="true">Yes</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Wifi</label>
                    <select class="form-select" name="listing[amenities][wifi]">
                        <option value="false" selected>No</option>
                        <option value="true">Yes</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Free Parking</label>
                    <select class="form-select" name="listing[amenities][freeParking]">
                        <option value="false" selected>No</option>
                        <option value="true">Yes</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Pool</label>
                    <select class="form-select" name="listing[amenities][pool]">
                        <option value="false" selected>No</option>
                        <option value="true">Yes</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Shared Sauna</label>
                    <select class="form-select" name="listing[amenities][sharedSauna]">
                        <option value="false" selected>No</option>
                        <option value="true">Yes</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label">TV</label>
                    <select class="form-select" name="listing[amenities][tv]">
                        <option value="false" selected>No</option>
                        <option value="true">Yes</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Lift</label>
                    <select class="form-select" name="listing[amenities][lift]">
                        <option value="false" selected>No</option>
                        <option value="true">Yes</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Washing Machine</label>
                    <select class="form-select" name="listing[amenities][washingMachine]">
                        <option value="false" selected>No</option>
                        <option value="true">Yes</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Dryer (In Unit)</label>
                    <select class="form-select" name="listing[amenities][dryer]">
                        <option value="false" selected>No</option>
                        <option value="true">Yes</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Security Cameras</label>
                    <select class="form-select" name="listing[amenities][securityCameras]">
                        <option value="false" selected>No</option>
                        <option value="true">Yes</option>
                    </select>
                </div>
            </div>
        </div>
        
        <button class="btn btn-dark add-btn mt-3">Add</button>
    </form>
    </div>
    </div>

</body>
</html>

