<% layout("/layouts/boilerplate") %> 

<style> 
  #filters {
    display: flex;
    flex-wrap: wrap;  
    align-items: center;
  }

  .filter {
    text-align: center;
    margin-right: 2rem;
    margin-top: 2rem;
    opacity: 0.7;
  }

  .filter:hover {
    opacity: 1;
    cursor: pointer;
  }

  .filter p {
    font-size: 0.8rem;
  }

  .filter.active {
    opacity: 1;
    border-bottom: 2px solid #222;
  }

  .filter-link {
    text-decoration: none;
    color: inherit;
  }

  .tax-info {
    display: none;
  }

  .tex-toggle {
    border: 1px solid black;
    border-radius: 1rem;
    height: 3.25rem;
    padding: 1rem;
    margin-left: 2rem;
    display: flex;
    align-items: center;
  }
</style>

<div id="filters">
  <a class="filter-link" href="/listings?category=trending<%= searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '' %>">
    <div class="filter <%= activeCategory === 'trending' ? 'active' : '' %>">
      <div><i class="fa-solid fa-fire"></i></div>
      <p>Trending</p>
    </div>
  </a>
  
  <a class="filter-link" href="/listings?category=rooms<%= searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '' %>">
    <div class="filter <%= activeCategory === 'rooms' ? 'active' : '' %>">
      <div><i class="fa-solid fa-bed"></i></div>
      <p>Rooms</p>
    </div>
  </a>

  <a class="filter-link" href="/listings?category=iconic-cities<%= searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '' %>">
    <div class="filter <%= activeCategory === 'iconic-cities' ? 'active' : '' %>">
      <div><i class="fa-solid fa-mountain-city"></i></div>
      <p>Iconic Cities</p>
    </div>
  </a>
  
  <a class="filter-link" href="/listings?category=mountains<%= searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '' %>">
    <div class="filter <%= activeCategory === 'mountains' ? 'active' : '' %>">
      <div><i class="fa-solid fa-mountain"></i></div>
      <p>Mountains</p>
    </div>
  </a>

  <a class="filter-link" href="/listings?category=castles<%= searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '' %>">
    <div class="filter <%= activeCategory === 'castles' ? 'active' : '' %>">
      <div><i class="fa-solid fa-chess-rook"></i></div>
      <p>Castles</p>
    </div>
  </a>
  
  <a class="filter-link" href="/listings?category=arctic<%= searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '' %>">
    <div class="filter <%= activeCategory === 'arctic' ? 'active' : '' %>">
      <div><i class="fa-solid fa-snowflake"></i></div>
      <p>Arctic</p>
    </div>
  </a>

  <a class="filter-link" href="/listings?category=camping<%= searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '' %>">
    <div class="filter <%= activeCategory === 'camping' ? 'active' : '' %>">
      <div><i class="fa-solid fa-campground"></i></div>
      <p>Camping</p>
    </div>
  </a>

  <a class="filter-link" href="/listings?category=farms<%= searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '' %>">
    <div class="filter <%= activeCategory === 'farms' ? 'active' : '' %>">
      <div><i class="fa-solid fa-cow"></i></div>
      <p>Farms</p>
    </div>
  </a>

  <a class="filter-link" href="/listings?category=domes<%= searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '' %>">
    <div class="filter <%= activeCategory === 'domes' ? 'active' : '' %>">
      <div><i class="fa-solid fa-igloo"></i></div>
      <p>Domes</p>
    </div>
  </a>

  <a class="filter-link" href="/listings?category=boats<%= searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '' %>">
    <div class="filter <%= activeCategory === 'boats' ? 'active' : '' %>">
      <div><i class="fa-solid fa-ship"></i></div>
      <p>Boats</p>
    </div>
  </a>

  <div class="tex-toggle"> 
    <div class="form-check-reverse form-switch">
      <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
      <label class="form-check-label" for="switchCheckDefault">Display total after taxes</label>
    </div>
  </div>
</div>

<% const categoryLabelMap = { "trending": "Trending", "rooms": "Rooms", "iconic-cities": "Iconic Cities", "mountains": "Mountains", "castles": "Castles", "arctic": "Arctic", "camping": "Camping", "farms": "Farms", "domes": "Domes", "boats": "Boats" }; %>
<% if (activeCategory) { %>
  <div class="mt-2">
    <p class="mb-0">Category: <b><%= categoryLabelMap[activeCategory] %></b></p>
  </div>
<% } %>

<% if (searchQuery && searchQuery.length) { %>
  <div class="mt-3">
    <p class="mb-0">
      Search results for: <b><%= searchQuery %></b>
      (<%= allListings.length %> found)
    </p>
  </div>
<% } %>

<% if (!allListings.length) { %>
  <div class="alert alert-warning mt-3" role="alert">
    No listings found for this search.
  </div>
<% } %>


<div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
  <% for (let listing of allListings) { %>
    <% const previewImage = (listing.images && listing.images.length) ? listing.images[0].url : (listing.image ? listing.image.url : ""); %>
    <a href="/listings/<%= listing._id %>" class="listing-link">
      <div class="card col listing-card">
        <img
          src="<%= previewImage %>"
          class="card-img-top"
          alt="listing_image"
          style="height: 20rem;"
        />
        <div class="card-img-overlay"></div>
        <div class="card-body">
          <p class="card-text">
            <b><%= listing.title %> </b><br />
            &#8377; <%= listing.price.toLocaleString("en-IN") %> / night
            <i class="tax-info" data-base-price="<%= listing.price %>"></i>
          </p>
        </div>
      </div>
    </a>
  <% } %>
</div>

<button
  id="chatbotToggleBtn"
  class="chatbot-toggle-btn"
  type="button"
  aria-label="Open chatbot"
>
  <i class="fa-solid fa-comment-dots"></i>
</button>

<section id="chatbotWidget" class="chatbot-widget" aria-live="polite">
  <div class="chatbot-header">
    <h6 class="chatbot-title">Wanderstay Assistant</h6>
    <button id="chatbotCloseBtn" class="chatbot-close-btn" type="button" aria-label="Close chatbot">
      <i class="fa-solid fa-xmark"></i>
    </button>
  </div>
  <div id="chatbotMessages" class="chatbot-messages">
    <div class="chatbot-msg chatbot-msg-bot">
      Hi! Ask me about booking, payment, account, wishlist, or ask: find stays in Goa.
    </div>
  </div>
  <form id="chatbotForm" class="chatbot-form">
    <input
      id="chatbotInput"
      class="chatbot-input"
      type="text"
      placeholder="Type your question..."
      maxlength="300"
      required
    />
    <button id="chatbotSendBtn" class="chatbot-send-btn" type="submit">Send</button>
  </form>
</section>

<script>
  let taxSwitch = document.getElementById("switchCheckDefault"); 
  taxSwitch.addEventListener("click", () => {
    let taxInfo = document.getElementsByClassName("tax-info");
    for (let info of taxInfo) {
      if (info.style.display !== "inline") {
        const basePrice = Number(info.dataset.basePrice || 0);
        const totalAfterTax = Math.round(basePrice * 1.18);
        info.innerText = `  Total with 18% GST: \u20B9 ${totalAfterTax.toLocaleString("en-IN")}`;
        info.style.display = "inline";
      } else {
        info.style.display = "none";
      }
    }
  });
</script>

